[Unit]
Description=Build server gateway — GitHub webhook entry + worker dispatcher
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/build-server
EnvironmentFile=/opt/build-server/.env
ExecStart=/opt/build-server/venv/bin/uvicorn runner_pool.gateway:app --host 127.0.0.1 --port 3000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
