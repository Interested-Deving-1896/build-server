[Unit]
Description=GitHub Actions Runner Pool
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/build-server/runner_pool
EnvironmentFile=/opt/build-server/.env
ExecStart=/opt/build-server/venv/bin/uvicorn main:app --host 127.0.0.1 --port 3000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
