# GitHub App credentials — required on every node (master and slaves) because
# each node mints its own installation token before spawning a runner container.
# Create a GitHub App at https://github.com/settings/apps/new with permissions:
#   actions:read, checks:write, metadata:read, organization_self_hosted_runners:write
# Install it on each org at: https://github.com/settings/apps/<app-name>/installations
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret — must match the secret configured in the GitHub App webhook settings.
# Only the master needs to receive GitHub webhooks; slaves can omit this.
WEBHOOK_SECRET=

# Internal master ↔ slave secret. Must be identical on master and every slave.
# Used to authenticate the master's POST /spawn calls to slaves.
INTERNAL_SECRET=

# Default runner image (used when no runner-image: label is present)
DEFAULT_RUNNER_IMAGE=myoung34/github-runner:ubuntu-jammy

# Comma-separated list of allowed GitHub orgs/users. Leave empty to allow all App installations.
ALLOWED_ORGS=

# MASTER ONLY — comma-separated URLs of slave workers. Master polls each
# /capacity in parallel on every webhook and dispatches to the worker with
# the most free RAM (itself included). Leave empty for standalone.
# SLAVE_URLS=http://10.0.0.2,http://10.0.0.3
# WORKER_CAPACITY_TIMEOUT_S=2.0

# RAM-based scheduler (applies to every node — no fixed runner cap).
#
# MIN_FREE_RAM_MB: refuse to spawn when MemAvailable drops below this.
# WORST_CASE_RUNNER_MB: assumed peak RAM of a single runner (android/java/e2e).
#                  While headroom (avail - MIN_FREE_RAM_MB) >= this, spawns burst freely.
# SPAWN_COOLDOWN_S: when headroom shrinks below worst-case, throttle to one
#                  spawn per cooldown so MemAvailable reflects reality.
# MIN_FREE_RAM_MB=3072
# WORST_CASE_RUNNER_MB=3072
# SPAWN_COOLDOWN_S=15

# MASTER ONLY — pending queue for jobs that no worker could accept right now.
# Drainer retries every PENDING_DRAIN_INTERVAL_S; gives up after PENDING_JOB_DEADLINE_S.
# PENDING_JOB_DEADLINE_S=3600
# PENDING_DRAIN_INTERVAL_S=5

# Max seconds a runner may sit idle (no job picked up) before being killed (default: 600).
# RUNNER_IDLE_TIMEOUT=600

# Max seconds a runner may spend executing a job once it has started (default: 7200).
# RUNNER_JOB_TIMEOUT=7200

# Optional: Telegram alerts when a runner is idle for more than RUNNER_IDLE_ALERT_SECS seconds.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# RUNNER_IDLE_ALERT_SECS=300
