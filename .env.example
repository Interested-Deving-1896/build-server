# GitHub App credentials (App ID: 3743839 — jakwuh-build-server, private)
# Install the App on each org at: https://github.com/settings/apps/jakwuh-build-server/installations
GITHUB_APP_ID=3743839
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret — must match the secret set in the GitHub App webhook config
WEBHOOK_SECRET=bfeeef8b6ce4f7ae70fb705e82c0eb32c134205d02ad223b0ceb52e79830dd45

# Default runner image (used when no runner-image: label is present)
DEFAULT_RUNNER_IMAGE=myoung34/github-runner:ubuntu-jammy

# Comma-separated list of allowed GitHub orgs/users. Leave empty to allow all App installations.
# Any org not in this list gets a 200 response but no runner is spawned.
ALLOWED_ORGS=jakwuh,izi-x

# Optional: override auto-detected concurrency limit (default: os.cpu_count())
# CPU-bound builds -> set to vCPU count
# Memory-bound builds -> set to floor(RAM_GB / peak_job_GB)
# MAX_RUNNERS=8

# Max seconds a runner may sit idle (no job picked up) before being killed (default: 600).
# RUNNER_IDLE_TIMEOUT=600

# Max seconds a runner may spend executing a job once it has started (default: 7200).
# RUNNER_JOB_TIMEOUT=7200

# Telegram alerts for stuck runners (idle >N seconds without picking up a job).
# Bot: op://Miraj | AI/app-shared/telegram_bot_token
# Chat: op://Miraj | AI/app-shared/telegram_alerts_chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# RUNNER_IDLE_ALERT_SECS=300
