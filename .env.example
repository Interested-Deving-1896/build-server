# GitHub App credentials
# Create the App at: https://github.com/settings/apps/new
# Required permissions:
#   Organization permissions -> Self-hosted runners: Read & write
# Subscribe to events: Workflow jobs
# After creating, generate a private key and set both fields below.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret — set the same value in the GitHub App's webhook settings
WEBHOOK_SECRET=

# Default runner image (used when no runner-image: label is present)
DEFAULT_RUNNER_IMAGE=myoung34/github-runner:ubuntu-jammy

# Optional: override auto-detected concurrency limit (default: os.cpu_count())
# CPU-bound builds -> set to vCPU count
# Memory-bound builds -> set to floor(RAM_GB / peak_job_GB)
# MAX_RUNNERS=8
