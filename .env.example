# GitHub Personal Access Token with admin:org scope
# Used to register runners with any org this account is an admin of.
# To add a new org: create an org webhook (see README) pointing to this server.
GITHUB_PAT=ghp_...

# Webhook secret — must match the secret set in each org's webhook config
WEBHOOK_SECRET=

# Default runner image (used when no runner-image: label is present)
DEFAULT_RUNNER_IMAGE=myoung34/github-runner:ubuntu-jammy

# Optional: override auto-detected concurrency limit (default: os.cpu_count())
# CPU-bound builds -> set to vCPU count
# Memory-bound builds -> set to floor(RAM_GB / peak_job_GB)
# MAX_RUNNERS=8
