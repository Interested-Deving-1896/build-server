# ---- Auth (required) ----
# GitHub App credentials — every node (master + slaves) needs these to mint
# installation tokens for runner registration. Create the App at
# https://github.com/settings/apps/new with permissions:
#   actions:read, checks:write, metadata:read, organization_self_hosted_runners:write
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret — must match the GitHub App's webhook secret. Master only;
# slaves don't receive GitHub webhooks.
WEBHOOK_SECRET=

# Shared master ↔ slave secret for internal POST /spawn calls. Identical on
# every node in the fleet.
INTERNAL_SECRET=

# ---- Topology + security ----
# MASTER ONLY: comma-separated slave URLs. Master polls each /capacity and
# dispatches to the worker (itself or a slave) with the most free RAM.
# SLAVE_URLS=http://10.0.0.2,http://10.0.0.3

# Comma-separated allowed GitHub orgs. Empty = allow all App installations.
ALLOWED_ORGS=

# ---- Workload ----
# Default runner image when no runner-image: label is on the job.
DEFAULT_RUNNER_IMAGE=myoung34/github-runner:ubuntu-jammy

# Max seconds a runner may spend executing a single job (default 30 min).
# Bump if you have long-running e2e/integration suites.
# RUNNER_JOB_TIMEOUT=1800

# ---- Capacity gate (per node, depends on host) ----
# RAM-based scheduler. There is no fixed runner cap — concurrency is gated by
# how much RAM you want to always keep free. One knob:
#
#   avail < MIN_FREE_RAM_MB              → refuse
#   MIN_FREE_RAM_MB ≤ avail < 2 × MIN    → tight, throttle (one spawn / 15s)
#   avail ≥ 2 × MIN_FREE_RAM_MB          → burst (no throttle)
#
# In-flight reservation: each recent spawn (last 60s) is treated as already
# owing MIN_FREE_RAM_MB worth of allocation so a webhook stampede can't race
# past this gate before kernel sees real allocation.
# MIN_FREE_RAM_MB=3072

# ---- SLA alert (master only) ----
# Alert when a workflow_job sits in GitHub's queue longer than this before any
# runner picks it up. Measured queued→in_progress per job_id.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# LATENCY_ALERT_S=300
