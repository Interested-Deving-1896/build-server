# ---- Auth (required by both gateway and runner) ----
# GitHub App credentials. Gateway uses them for the queue poller; runner uses
# them to mint installation tokens for runner registration.
# Create the App at https://github.com/settings/apps/new with permissions:
#   actions:read, checks:write, metadata:read, organization_self_hosted_runners:write
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret — must match the GitHub App's webhook secret. Used by GATEWAY
# to verify incoming GitHub webhooks. Runner-only hosts don't need it.
WEBHOOK_SECRET=

# Shared gateway ↔ runner secret for internal POST /spawn calls. Identical on
# every node in the fleet.
INTERNAL_SECRET=

# Comma-separated allowed GitHub orgs. Empty = allow all App installations.
ALLOWED_ORGS=

# ==== GATEWAY-only config ====
# Comma-separated runner URLs. The gateway polls each /capacity and dispatches
# to whichever has the most free RAM. For a single-host deploy where the
# gateway and runner run on the same box, use the runner's local URL.
# WORKERS=http://127.0.0.1:3001
#
# Alert when a workflow_job sits queued longer than this before any runner
# picks it up. Measured queued→in_progress per job_id.
# LATENCY_ALERT_S=300
#
# Optional Telegram for SLA / worker-health alerts:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ==== RUNNER-only config ====
# Default runner image when no `runner-image:` label is on the job.
DEFAULT_RUNNER_IMAGE=myoung34/github-runner:ubuntu-jammy
#
# Capacity gate. Single knob — how much RAM to always keep free for OS + spike.
#   avail < MIN_FREE_RAM_MB           → refuse
#   MIN ≤ avail < 2 × MIN             → tight, throttle (1 spawn / 15s)
#   avail ≥ 2 × MIN                   → burst
# In-flight reservation: each recent spawn (last 60s) is treated as already
# owing MIN_FREE_RAM_MB so a webhook stampede can't race past this gate.
# MIN_FREE_RAM_MB=3072
#
# Max seconds a runner may spend executing a single job (default 30 min).
# RUNNER_JOB_TIMEOUT=1800
